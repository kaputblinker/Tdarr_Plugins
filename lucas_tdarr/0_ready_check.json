    {
      "name": "Lookup nominal bitrate for resolution",
      "sourceRepo": "Community",
      "pluginName": "customFunction",
      "version": "1.0.0",
      "id": "Qb3DSpeol",
      "position": {
        "x": 672,
        "y": 60
      },
      "fpEnabled": true,
      "inputsDB": {
        "code": "module.exports = async (args) => {\n    // Use the caller-provided normalized resolution label directly.\n    const resolutionLabel = String(args.inputFileObj?.video_resolution || '').trim();\n\n    if (!resolutionLabel) {\n        throw new Error('Missing args.inputFileObj.video_resolution');\n    }\n\n    // Derived via a combination of me looking at past results and me making stuff up.\n    // These are somewhat generous to try and make sure that even more visually complex stuff, will be around this.\n    // There are ofc very complex exceptions that get transcoded for very little benefit. Mainly Avatar 3. That thing is bananas.\n    const bitrateLookupKbps = {\n        '480p': 1100,\n        '576p': 1800,\n        '720p': 2700,\n        '1080p': 3200,\n        '1440p': 5500,\n        '4KUHD': 11000,\n        'DCI4K': 12500,\n        '8KUHD': 15000\n    };\n\n    const targetBitrateKbps = bitrateLookupKbps[resolutionLabel];\n\n    if (!targetBitrateKbps) {\n        const valid = Object.keys(bitrateLookupKbps).join(', ');\n        throw new Error(\n            'Unsupported video_resolution \"' +\n            resolutionLabel +\n            '\". Expected one of: ' +\n            valid\n        );\n    }\n    \n    // Set flow variables for downstream steps.\n    args.variables = args.variables || {};\n    args.variables.targetBitrateKbps = targetBitrateKbps;\n    args.variables.videoTranscodeThresholdKps = targetBitrateKbps * 1.3;\n    args.variables.overallBitrateThresholdKps = targetBitrateKbps * 1.5;\n    args.variables.maxBitrate4x = String(targetBitrateKbps * 4) + 'k';\n    args.variables.maxBitrate8x = String(targetBitrateKbps * 8) + 'k';\n\n    args.jobLog(\n        'lookupMaxBitrate: resolution=' +\n        resolutionLabel +\n        ', target=' +\n        targetBitrateKbps +\n        'k, threshold=' +\n        args.variables.videoTranscodeThresholdKps +\n        'k, max4x=' +\n        args.variables.maxBitrate4x +\n        'k, max8x=' +\n        args.variables.maxBitrate8x +\n        'k'\n    );\n\n    return {\n        outputFileObj: args.inputFileObj,\n        outputNumber: 1,\n        variables: args.variables\n    };\n};"
      }
    },
